{
    "prefix": "arcl-domainnet",
    "dataset": "domainnet",
    "domainnet_root": "./data/domainnet",
    "domainnet_train_txt": "./utils/datautils/domainnet/train.txt",
    "domainnet_test_txt": "./utils/datautils/domainnet/test.txt",
    "memory_size": 0,
    "memory_per_class": 0,
    "fixed_memory": false,
    "shuffle": true,
    "init_cls": 20,
    "increment": 20,
    "model_name": "arcl",
    "backbone_type": "pretrained_vit_b16_224_in21k_arcl",
    "device": ["0"],
    "seed": [2025],
    "swanlab": true,
    "pretrained": true,

    "epochs": 5,
    "batch_size": 64,
    "num_workers": 12,
    "use_amp": true,
    "temperature": 30.0,

    "lr": 0.01,
    "lr_scale": 0.01,
    "lr_scale_patterns": ["qkv"],
    "optimizer": "mod_adam",
    "weight_decay": 0.00005,
    "lr_sch": "multistep",
    "min_lr": 0.00001,
    "decay_milestones": [5, 8],
    "decay_rate": 0.1,

    "use_update_scaling": true
}
