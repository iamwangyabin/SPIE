{
    "prefix": "arcl-cifar",
    "dataset": "cifar224",
    "memory_size": 0,
    "memory_per_class": 0,
    "fixed_memory": false,
    "shuffle": true,
    "init_cls": 10,
    "increment": 10,
    "model_name": "arcl",
    "backbone_type": "pretrained_vit_b16_224_in21k_arcl",
    "device": [
        "0"
    ],
    "seed": [
        2026
    ],
    "swanlab": true,
    "swanlab_project": "SPIE",
    "swanlab_mode": "online",
    "pretrained": true,
    "epochs": 5,
    "batch_size": 100,
    "num_workers": 8,
    "use_amp": true,
    "lr": 0.01,
    "lr_scale": 0.01,
    "lr_scale_patterns": [
        "qkv"
    ],
    "weight_decay": 5e-05,
    "min_lr": 1e-05,
    "optimizer": "mod_adam",
    "lr_sch": "multistep",
    "decay_milestones": [
        5,
        8
    ],
    "decay_rate": 0.1,
    "temperature": 30.0,
    "use_update_scaling": true
}
