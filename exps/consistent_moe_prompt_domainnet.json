{
    "prefix": "consistent-moe-prompt-domainnet",
    "dataset": "domainnet",
    "domainnet_root": "./data/domainnet",
    "domainnet_train_txt": "./utils/datautils/domainnet/train.txt",
    "domainnet_test_txt": "./utils/datautils/domainnet/test.txt",
    "memory_size": 0,
    "memory_per_class": 0,
    "fixed_memory": false,
    "shuffle": true,
    "init_cls": 20,
    "increment": 20,
    "model_name": "consistent_moe_prompt",
    "backbone_type": "vit_base_patch16_224_in21k_consistent_moe_prompt",
    "device": ["0"],
    "seed": [2024],
    "swanlab": true,
    "swanlab_project": "SPIE",
    "swanlab_mode": "online",

    "tuned_epoch": 10,
    "init_lr": 0.01,
    "batch_size": 360,
    "eval_batch_size": 100,
    "weight_decay": 0.00005,
    "min_lr": 0.00001,
    "optimizer": "mod_adam",
    "scheduler": "steplr",
    "init_milestones": [5, 8],
    "init_lr_decay": 0.1,

    "pretrained": true,
    "prompt_len": 4,
    "prompt_start_block": 0,
    "prompt_end_block": 11,
    "moe_num_experts": 36,
    "moe_topk": 16,
    "moe_noisy_gating": true,
    "moe_impt_coef": 0.05,
    "moe_frozen_qx_coef": 0.0,
    "temperature": 30.0,
    "training_string": ["w_gate", "w_noise", "experts"],

    "use_null_space": true,
    "null_patterns": ["experts", "w_gate"],
    "null_thres_mode": "adaptive",
    "null_thres_value1": 0.0,
    "null_thres_value2": 0.0,
    "null_eta1": 1.0,
    "null_eta2": 0.99
}
