{
    "prefix": "mqmk-domainnet",
    "dataset": "domainnet",
    "domainnet_root": "./data/domainnet",
    "domainnet_train_txt": "./utils/datautils/domainnet/train.txt",
    "domainnet_test_txt": "./utils/datautils/domainnet/test.txt",
    "memory_size": 0,
    "memory_per_class": 0,
    "fixed_memory": false,
    "shuffle": true,
    "init_cls": 20,
    "increment": 20,
    "model_name": "mqmk",
    "backbone_type": "vit_base_patch16_224_in21k_mqmk",
    "mqmk_base_model": "vit_base_patch16_224_in21k",
    "device": ["0"],
    "seed": [1993],

    "tuned_epoch": 430,
    "init_lr": 0.005,
    "batch_size": 64,
    "weight_decay": 0.0,
    "min_lr": 0.0,
    "optimizer": "adam",
    "scheduler": "constant",
    "reinit_optimizer": true,
    "init_milestones": [10],
    "init_lr_decay": 0.1,
    "pretrained": true,
    "drop": 0.0,
    "drop_path": 0.0,
    "clip_grad": 1.0,

    "multi_query": true,
    "multi_key": true,
    "mq_top_k": 1,
    "pool_size": 10,
    "prompt_length": 90,
    "embedding_key": "cls",
    "prompt_init": "uniform",
    "prompt_key": true,
    "prompt_key_init": "uniform",
    "batchwise_prompt": false,
    "use_prompt_mask": true,
    "pull_constraint": true,
    "pull_constraint_coeff": 1.0,
    "perfect_match": false,

    "use_g_prompt": true,
    "g_prompt_length": 5,
    "g_prompt_layer_idx": [0, 1],
    "use_e_prompt": true,
    "e_prompt_layer_idx": [2, 3, 4, 5, 6, 7, 8, 9, 10],
    "same_key_value": false,
    "k_key": 1,
    "class_group": 1
}
